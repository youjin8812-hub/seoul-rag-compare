# Supabase (pgvector) - Project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-service-role-or-secret-key

# OpenRouter - https://openrouter.ai/keys
# used for both embeddings(openai/text-embedding-3-small) and chat(openai/gpt-5-mini)
OPENROUTER_API_KEY=sk-or-v1-...

# Cohere - https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your-cohere-api-key

# (선택) Parent 문맥 확장에 사용할 parents.jsonl 경로. 기본값: data/chunks_page_01_10/parents.jsonl
# PARENTS_JSONL_PATH=data/chunks_page_01_10/parents.jsonl
